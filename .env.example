# ============================================================
# Environment Variables Configuration
#
# IMPORTANT: This file contains sensitive credentials!
# - NEVER commit this file to version control
# - This file is already in .gitignore
# - For production, use secrets management (HCP Vault, AWS Secrets Manager, etc.)
# ============================================================

# ── PostgreSQL Database Configuration ─────────────────────────────────────────
POSTGRES_USER=wati_user
POSTGRES_PASSWORD=
POSTGRES_DB=wati_db
POSTGRES_HOST=postgres

# ── HCP Vault Secrets Configuration ─────────────────────────────────────────
HCP_CLIENT_ID=
HCP_CLIENT_SECRET=
HCP_PROJECT_ID=

# ── NVIDIA NIM APIs (OCR, Nemotron, SDXL) ────────────────────────────────────
NVIDIA_API_KEY=

# ── Groq Whisper API (Speech-to-Text) ────────────────────────────────────────
GROQ_API_KEY=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

# ── Telegram Bot Configuration ───────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_USER_ID=

# ── Database Connection String ───────────────────────────────────────────────
DB_URL=postgresql://wati_user:@postgres:5432/wati_db

# ── Telemetry & Observability ────────────────────────────────────────────────
ADMIN_API_KEY=
EXTERNAL_API_KEY=          # Shared secret between Telegram Bot and Backend
# NOTE: VITE_UMAMI_WEBSITE_ID goes in frontend/.env.local (not here)
UMAMI_APP_SECRET=
